generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Contest {
  id        String   @id @default(cuid())
  title     String
  url       String   @unique
  startTime DateTime
  duration  Int
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
}

model User {
  id        String   @id
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  handles   Handle[]
}

model Handle {
  id            String   @id @default(cuid())
  platform      String
  username      String
  rating        Int?
  highestRating Int?
  userId        String
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
}
